[configuration]

entry_symbol = "libmpv_zero_library_init"
compatibility_minimum = "4.6"
reloadable = false

[libraries]
; Relative paths ensure that our GDExtension can be placed anywhere in the project directory.
windows.x86_64.single.debug = "./windows/libmpv_zero.windows.template_debug.x86_64.dll"
windows.x86_64.single.release = "./windows/libmpv_zero.windows.template_release.x86_64.dll"
